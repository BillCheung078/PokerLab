{{ define "dashboard" }}{{ template "base" . }}{{ end }}

{{ define "content" }}
<main class="dashboard">
  <section class="hero">
    <p class="eyebrow">Technical Assignment</p>
    <h1>{{ .Title }}</h1>
    <p class="lede">
      The dashboard now uses one shared browser stream and multiplexes events to
      each table card while add and remove actions stay server-driven.
    </p>
  </section>
  {{ template "dashboard-content" . }}
</main>
{{ end }}
