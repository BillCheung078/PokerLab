{{ define "dashboard" }}{{ template "base" . }}{{ end }}

{{ define "content" }}
<main class="dashboard">
  <section class="hero">
    <p class="eyebrow">Phase 2</p>
    <h1>{{ .Title }}</h1>
    <p class="lede">
      Session-owned tables can now be added, removed, and restored after a page
      refresh. Streaming arrives in the next phase.
    </p>
  </section>
  {{ template "dashboard-content" . }}
</main>
{{ end }}
